#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/bt.h>

&inc_dec_kp {
	triggers-per-rotation = <60>;   // knob steps per full turn. Lower = coarser, higher = finer.
};
&def_lshft {
	triggers-per-rotation = <4>;    // leave this — controls layer-switching speed
};

/ {
	keymap {
		compatible = "zmk,keymap";

		// LAYER 0 — knob = Left/Right arrows (side-scroll substitute)
		default_layer {
			// Copy | Cut (tap=cut, HOLD=switch layers) | Paste
			bindings = <&kp LC(C) &lt 4 LC(X) &kp LC(V)>;
			sensor-bindings = <&inc_dec_kp RIGHT LEFT>;
		};

		// LAYER 1 — knob = monitor brightness (via Twinkle Tray hotkeys)
		one {
			bindings = <&kp LC(C) &lt 4 LC(X) &kp LC(V)>;
			sensor-bindings = <&inc_dec_kp LC(LA(PG_UP)) LC(LA(PG_DN))>;
		};

		// LAYER 2 — knob = volume (kept from the original config so you don't lose it)
		two {
			bindings = <&kp LC(C) &lt 4 LC(X) &kp LC(V)>;
			sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
		};

		// LAYER 3 — knob = page up/down (spare, vertical scroll-ish)
		three {
			bindings = <&kp LC(C) &lt 4 LC(X) &kp LC(V)>;
			sensor-bindings = <&inc_dec_kp PG_UP PG_DN>;
		};

		// LAYER 4 — SELECTOR. Do not change. Hold middle button + turn knob to pick a layer.
		shift {
			bindings = <&bt BT_CLR &trans &rgb_ug RGB_TOG>;
			sensor-bindings = <&def_lshft>;
		};
	};
};
